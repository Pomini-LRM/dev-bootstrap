# ============================================================
# dev-bootstrap - Environment variables
# ============================================================
# Copy this file to .env and fill in required values.
# Never commit .env to source control.
# ============================================================

# --- GitHub ---
# Classic token with scopes: repo, read:org
GITHUB_TOKEN=

# --- Azure DevOps ---
# PAT with at least Code:Read
AZURE_DEVOPS_PAT=
# Required organization list (comma-separated), for example: org-one,org-two
AZURE_DEVOPS_ORGS=

# --- Azure Container Registry ---
# Azure tenant id
AZURE_TENANT_ID=
